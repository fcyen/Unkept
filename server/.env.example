# Copy to server/.env (gitignored) and fill in your provider details.
# Used by routes/aesthetic.js — the vision-LLM keeper-scoring proxy.
# Without these, the /api/aesthetic/health endpoint returns 503 and the
# pipeline's aesthetic stage gracefully degrades (scores stay null,
# heroSelect falls back to its classical heuristic).

# OpenAI-compatible base URL. The proxy works with any provider that
# speaks OpenAI's chat.completions API:
#   Kimi (Moonshot)   https://api.moonshot.ai/v1
#   OpenAI            https://api.openai.com/v1
# LLM_BASE_URL=https://api.moonshot.ai/v1

# Provider API key.
# LLM_API_KEY=sk-...

# Vision-capable model name from the provider:
#   Kimi    moonshot-v1-8k-vision-preview
#   OpenAI  gpt-4o-mini
# LLM_MODEL=moonshot-v1-8k-vision-preview

# ── Optional second provider ──────────────────────────────────────────────
# Configure a second model to score every photo against both at once. The
# /pipeline view then shows a side-by-side comparison when a photo is
# selected. Provider A above stays authoritative (it drives heroSelect);
# provider B is comparison-only. Leave unset to run a single model.
# LLM_BASE_URL_2=https://api.openai.com/v1
# LLM_API_KEY_2=sk-...
# LLM_MODEL_2=gpt-4o-mini
