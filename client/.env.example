# Copy to .env.local for local dev, or set these in the Netlify build env.
# Both are optional — without them, telemetry stays inert (track() is a no-op).

# Public URL of the Supabase telemetry Edge Function (write-only gateway,
# holds no secret). Substitute your project ref:
# VITE_TELEMETRY_ENDPOINT=https://<PROJECT_REF>.supabase.co/functions/v1/track

# Build identifier stamped onto each event (e.g. the git SHA). Netlify
# exposes COMMIT_REF; wire it through as VITE_APP_VERSION in netlify.toml or
# the build command. Defaults to "dev" when unset.
# VITE_APP_VERSION=
